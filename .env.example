# Configuration de l'environnement DECEL
# Copiez ce fichier en .env et remplissez les valeurs réelles

# Django Secret Key - IMPORTANT: Changez cette valeur en production!
# Générez une nouvelle clé avec: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-this-in-production-use-environment-variable

# DEBUG Mode - Mettez à False en production
DEBUG=True

# Allowed Hosts - Séparez les hôtes par des virgules
# Exemple: localhost,127.0.0.1,mondomaine.com,www.mondomaine.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (optionnel - utilise SQLite par défaut)
# DATABASE_URL=postgresql://user:password@localhost:5432/deceldb

# Stripe Configuration (pour les paiements)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Configuration (optionnel)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_password

# Cache Configuration
CACHE_BACKEND=django.core.cache.backends.filebased.FileBasedCache
CACHE_LOCATION=/tmp/django_cache
